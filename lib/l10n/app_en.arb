  "helpTitle": "Help",
  "@helpTitle": {
    "description": "Help screen title and menu label"
  },
  "helpIntro": "BirdNET Live is built around a small set of repeatable screens: Home, mode screens, Session Review, and Settings. This help page explains what the app is showing and where the main controls live.",
  "@helpIntro": {
    "description": "Introduction paragraph on the help screen"
  },
  "helpLiveTitle": "Live Mode",
  "@helpLiveTitle": {
    "description": "Section title for Live mode help"
  },
  "helpLiveBody": "Live Mode opens the microphone, shows model status in the top bar, and updates the spectrogram and detection list continuously. The large center button changes between mic, play, and stop depending on state, and the settings button opens the Live-specific controls.",
  "@helpLiveBody": {
    "description": "Help body text for Live mode"
  },
  "helpPointCountTitle": "Point Count Mode",
  "@helpPointCountTitle": {
    "description": "Section title for Point Count help"
  },
  "helpPointCountBody": "Point Count Mode uses a short setup flow for duration and location, then switches to a timed live screen. The top bar shows stop, remaining time, and settings, while the info bar summarizes detections and unique species during the count.",
  "@helpPointCountBody": {
    "description": "Help body text for Point Count mode"
  },
  "helpSurveyTitle": "Survey Mode",
  "@helpSurveyTitle": {
    "description": "Section title for Survey mode help"
  },
  "helpSurveyBody": "Survey Mode starts with details and parameter steps, then opens a live dashboard with Map, Spectrogram, and Summary tabs. The top bar holds stop, help, and settings, and recent detections below the tabs open the species overlay when tapped.",
  "@helpSurveyBody": {
    "description": "Help body text for Survey mode"
  },
  "helpFileAnalysisTitle": "File Analysis",
  "@helpFileAnalysisTitle": {
    "description": "Section title for File Analysis help"
  },
  "helpFileAnalysisBody": "File Analysis is a four-step wizard: pick a file, set location and date, choose parameters, and run analysis. The settings button opens the File Analysis settings subset, and completed analyses open in Session Review.",
  "@helpFileAnalysisBody": {
    "description": "Help body text for File Analysis mode"
  },
  "helpBatchAnalysisTitle": "Batch Analysis",
  "@helpBatchAnalysisTitle": {
    "description": "Section title for Batch Analysis help"
  },
  "helpBatchAnalysisBody": "Batch Analysis is designed for many files at once. Select multiple recordings, confirm shared parameters, and run one queue that processes each file and stores results for later review.",
  "@helpBatchAnalysisBody": {
    "description": "Help body text for Batch Analysis mode"
  },
  "helpAruTitle": "ARU Mode",
  "@helpAruTitle": {
    "description": "Section title for ARU help"
  },
  "helpAruBody": "ARU Mode schedules fixed-site recording cycles and saves each deployment as an ARU Session. This early implementation can record full cycle audio and show an Android foreground notification; inference, detection-only clips, and full review playback are still in development.",
  "@helpAruBody": {
    "description": "Help body text for ARU mode"
  },
  "helpExploreTitle": "Explore",
  "@helpExploreTitle": {
    "description": "Section title for Explore help"
  },
  "helpExploreBody": "Explore builds a location-based species list from the BirdNET geo-model. Use refresh to rebuild the list, the help button in the location header for context, and tap any species card to open images, descriptions, links, and the seasonal chart.",
  "@helpExploreBody": {
    "description": "Help body text for Explore feature"
  },
  "helpSessionsTitle": "Sessions & Review",
  "@helpSessionsTitle": {
    "description": "Section title for Sessions help"
  },
  "helpSessionsBody": "Session Library stores saved sessions and processed files. From there you can search, sort, change view mode, and open Session Review. Session Review adds playback, spectrogram navigation, trimming, annotations, export, and save or discard actions.",
  "@helpSessionsBody": {
    "description": "Help body text for Sessions feature"
  },
  "helpTipsTitle": "App Basics",
  "@helpTipsTitle": {
    "description": "Section title for general tips"
  },
  "helpTipQuiet": "Use the settings button to open only the controls relevant to the current screen.",
  "@helpTipQuiet": {

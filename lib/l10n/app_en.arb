  "onboardingWelcomeBody": "AI-powered bioacoustic monitoring for field researchers and citizen scientists. Runs entirely on-device — no internet required.",
  "@onboardingWelcomeBody": {
    "description": "Onboarding welcome screen body text"
  },
  "onboardingHowItWorksTitle": "How It Works",
  "@onboardingHowItWorksTitle": {
    "description": "Onboarding how it works screen title"
  },
  "onboardingHowItWorksBody": "BirdNET Live continuously listens to your surroundings. It analyzes audio using an on-device artificial intelligence model to identify species in real-time. Detections are highlighted on a live scrolling spectrogram. Everything is processed locally, meaning it works entirely offline and protects your privacy.",
  "@onboardingHowItWorksBody": {
    "description": "Onboarding how it works body text"
  },
  "onboardingFeaturesTitle": "Four Modes",
  "@onboardingFeaturesTitle": {
    "description": "Onboarding features screen title"
  },
  "onboardingFeaturesBody": "Live monitoring, timed point counts, transect surveys, and offline file analysis — built for standardized field protocols with real-time spectrogram visualization.",
  "@onboardingFeaturesBody": {
    "description": "Onboarding features screen body text"
  },
  "onboardingPermissionsTitle": "Permissions",
  "@onboardingPermissionsTitle": {
    "description": "Onboarding permissions screen title"
  },
  "onboardingPermissionsBody": "BirdNET Live needs microphone access for audio capture and (optionally) location access for geotagging detections, GPS tracks in surveys, and location-based species filtering. Both can be revoked at any time in system settings.",
  "@onboardingPermissionsBody": {
    "description": "Onboarding permissions screen body text"
  },
  "onboardingTermsTitle": "Terms & Privacy",
  "@onboardingTermsTitle": {
    "description": "Onboarding terms & privacy screen title"
  },
  "onboardingTermsBody": "Detections are AI predictions, not confirmed observations — verify before reporting. Audio is processed on-device and never uploaded. The only network requests are optional map tiles and a single reverse-geocoding lookup per session to resolve coordinates into a place name; both require your one-time consent. Models (CC BY-SA 4.0) and the app may NOT be used for poaching or any military purpose. Tap below to read the full Terms of Use and Privacy Policy.",

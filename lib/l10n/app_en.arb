    "description": "Tooltip on the help (?) icon next to a setting"
  },
  "settingsHelpShowSciNames": "When enabled, scientific names appear in grey under common names throughout the app. Useful when you want unambiguous identification or are working with field guides that use Latin names.",
  "@settingsHelpShowSciNames": {
    "description": "Help text for the show scientific names setting"
  },
  "settingsHelpTimestampDisplayMode": "Choose how per-detection times are rendered in session review. 'Relative' shows the offset from the start of the recording (00:12:34) — best for reviewing a single session and matching the spectrogram playhead. 'Absolute' shows the local clock time when the detection was captured (08:42:17) — best for cross-referencing field notes, weather logs, or other recordings. Storage and exports always use UTC instants regardless of this setting, so the choice never affects your data.",
  "@settingsHelpTimestampDisplayMode": {
    "description": "Help text for timestamp display mode setting"
  },
  "settingsHelpTimestampShowSeconds": "When enabled, absolute detection times include the trailing seconds component (08:42:17). When disabled, they stop at minute precision (08:42), which can be easier to scan in long lists. Only affects absolute mode — relative offsets always show seconds for spectrogram alignment, and exported CSV and JSON files always include seconds regardless.",
  "@settingsHelpTimestampShowSeconds": {
    "description": "Help text for timestamp show seconds setting"
  },
  "settingsHelpGain": "Multiplies the microphone signal in the app. Use values above 1.0 only for very quiet recordings — high gain amplifies noise too and can cause clipping. Most built-in mics work best at 1.0.",
  "@settingsHelpGain": {
    "description": "Help text for gain setting"
  },
  "settingsHelpHighPassFilter": "Removes low-frequency content (wind, traffic, handling noise) before inference. Most species vocalize above 1 kHz, so a 100–200 Hz cut-off is usually safe and improves detection in noisy conditions.",
  "@settingsHelpHighPassFilter": {
    "description": "Help text for high-pass filter setting"
  },
  "settingsHelpWindowDuration": "How many seconds of audio BirdNET analyzes at once. Shorter windows react faster and give finer time resolution; longer windows average more context per pass for steadier scores at the cost of slower reaction time.",
  "@settingsHelpWindowDuration": {
    "description": "Help text for analysis window duration setting"
  },
  "settingsHelpConfidenceThreshold": "Detections below this score are hidden. Default is 35%. Lower values surface more uncertain detections (good for rare species or quiet recordings); higher values reduce false positives but may miss faint or distant calls.",
  "@settingsHelpConfidenceThreshold": {
    "description": "Help text for confidence threshold setting"
  },
  "settingsHelpSensitivity": "Logistic sigmoid steepness applied to model logits. Higher values push uncertain scores toward extremes (more high-confidence detections plus more false positives). Leave at 1.0 unless you know what you're doing.",
  "@settingsHelpSensitivity": {
    "description": "Help text for sensitivity setting"
  },
  "settingsHelpInferenceRate": "How often BirdNET runs inference per second. Higher rates catch brief calls but use more battery and CPU; lower rates are gentler on the device but may miss short vocalizations.",
  "@settingsHelpInferenceRate": {
    "description": "Help text for inference rate setting"
  },
  "settingsHelpScorePooling": "How scores from overlapping analysis windows are combined. 'Max' is most reactive; 'average' smooths flickering; 'LME' (log-mean-exp) is a soft maximum that balances both, requires repeated raw-window support before a new species first appears, and keeps supported high scores close to their strongest recent raw score.",
  "@settingsHelpScorePooling": {
    "description": "Help text for score pooling setting"
  },
  "settingsHelpScorePoolingWindows": "Number of consecutive inference windows that contribute to the pooled score. Larger values smooth detections over a longer time horizon — better for steady, distant calls but slower to react to brief vocalizations. Smaller values are more responsive but noisier.",
  "@settingsHelpScorePoolingWindows": {
    "description": "Help text for score pooling windows setting"
  },
  "settingsHelpFftSize": "Resolution of the spectrogram. Larger sizes give finer frequency detail but coarser timing; smaller sizes show transient calls more sharply but blur frequencies. 1024–2048 works well for most species.",
  "@settingsHelpFftSize": {
    "description": "Help text for FFT size setting"
  },
  "settingsHelpColorMap": "Color palette used to render spectrogram intensity. Viridis and Magma are perceptually uniform; Grayscale is print-friendly and emphasizes structure over hue.",
  "@settingsHelpColorMap": {
    "description": "Help text for spectrogram color map setting"
  },
  "settingsHelpSpectrogramDuration": "How many seconds of audio fit on screen at once. Shorter durations give more detail per call; longer durations show temporal patterns and let you compare detections.",
  "@settingsHelpSpectrogramDuration": {
    "description": "Help text for spectrogram duration setting"
  },
  "settingsHelpFrequencyRange": "Upper limit of the spectrogram's vertical axis. Reduce to focus on low-frequency vocalizations (owls, grouse) or increase to see ultrasonic calls and high-pitched insects.",
  "@settingsHelpFrequencyRange": {
    "description": "Help text for spectrogram frequency range setting"
  },
  "settingsHelpLogAmplitude": "Applies a logarithmic scale to spectrogram intensity. Makes quiet calls more visible at the cost of also showing more background noise. Helpful for distant or faint species.",
  "@settingsHelpLogAmplitude": {
    "description": "Help text for log amplitude setting"
  },
  "settingsHelpSpectrogramQuality": "Controls the GPU filtering used to render the live spectrogram. 'High' looks smoothest and is recommended on modern phones. Drop to 'Medium' or 'Low' on older devices if you see frame drops or excessive battery drain.",
  "@settingsHelpSpectrogramQuality": {
    "description": "Help text for spectrogram quality setting"
  },
  "settingsHelpRecordingMode": "Whether and how audio is saved to disk. 'Full' keeps everything (large files); 'Detections only' saves short clips around each detection; 'Off' analyzes in real time without writing audio.",
  "@settingsHelpRecordingMode": {
    "description": "Help text for recording mode setting"
  },
  "settingsHelpRecordingFormat": "Container format for saved audio. WAV is uncompressed and universally supported; FLAC is lossless but ~50% smaller and supported by most analysis software.",
  "@settingsHelpRecordingFormat": {
    "description": "Help text for recording format setting"
  },
  "settingsHelpUseGps": "Use the device's GPS for live location. When off, the app uses the manual coordinates you set below — useful for stationary deployments or when GPS reception is poor indoors.",
  "@settingsHelpUseGps": {
    "description": "Help text for use GPS setting"
  },
  "settingsHelpSpeciesFilter": "Restrict detections by geographic likelihood using the on-device location model. 'Location filter' hides species below the threshold; 'Location weighting' multiplies detection scores by the location prior.",
  "@settingsHelpSpeciesFilter": {
    "description": "Help text for species filter setting"
  },
  "settingsHelpGeoThreshold": "Minimum geographic-prior score for a species to pass the location filter. Lower values are more permissive (good for rare or migrating species); higher values stay strictly within typical ranges.",
  "@settingsHelpGeoThreshold": {
    "description": "Help text for geo threshold setting"
  },
  "settingsHelpExportFormat": "Format for exported session data. Raven is for use in Cornell Raven Pro; CSV opens in spreadsheets; JSON is easiest for programmatic processing; GPX writes the survey track and waypoints for use in mapping tools.",
  "@settingsHelpExportFormat": {
    "description": "Help text for export format setting"
  },
  "settingsHelpIncludeAudioFiles": "When enabled, exported sessions include the saved audio files alongside the metadata table. Useful for archiving and re-analysis; results in much larger exports.",
  "@settingsHelpIncludeAudioFiles": {
    "description": "Help text for include audio files setting"
  },
  "settingsHelpExportHtmlReport": "When enabled, the export ZIP also contains a self-contained `report.html`. Open it in any browser to see a styled session summary with map, per-detection cards, and inline audio players. Species images are loaded from the BirdNET taxonomy service when online.",
  "@settingsHelpExportHtmlReport": {
    "description": "Help text for export HTML report setting"
  },
